{
  "name": "phantom-ows-payments",
  "version": "0.1.0",
  "description": "Drop-in React Native library for Phantom embedded wallets + OWS-compliant policies + x402/MPP autonomous payments",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "example": "cd example && npx expo start",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@phantom/react-native-sdk": "^1.0.7",
    "react-native-get-random-values": "^1.11.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@solana/web3.js": ">=1.91.0",
    "expo-local-authentication": "*",
    "expo-secure-store": "*"
  },
  "peerDependenciesMeta": {
    "expo-local-authentication": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "phantom",
    "ows",
    "x402",
    "mpp",
    "embedded-wallet",
    "agent-payments",
    "solana",
    "react-native",
    "expo",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rkmonarch/phantom-ows-payments"
  },
  "license": "MIT"
}
